<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abyss">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- PAGE TITLE & ACTIONS -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp">

                <TextView
                    android:id="@+id/tv_cart_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="My Cart"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear_cart"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Clear All"
                    android:textColor="@color/tag_red"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconTint="@color/tag_red" />
            </RelativeLayout>

            <!-- EMPTY CART STATE -->
            <LinearLayout
                android:id="@+id/empty_cart_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    app:cardBackgroundColor="@color/white_10"
                    app:cardCornerRadius="80dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/white_20">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shopping_cart"
                        app:tint="@color/text_grey" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Your cart is feeling light"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Let's add some items!"
                    android:textColor="@color/text_grey"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start_shopping"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="@color/electric_blue"
                    android:text="Start Shopping"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="25dp"
                    app:icon="@android:drawable/ic_menu_compass"
                    app:iconGravity="textStart"
                    app:iconTint="@color/white" />
            </LinearLayout>

            <!-- CART ITEMS LIST -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_cart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false"
                android:visibility="visible"
                tools:listitem="@layout/item_cart" />

                <!-- CHECKOUT BOTTOM SHEET (Floating Card moved to scroll) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/checkout_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="40dp"
                    app:cardBackgroundColor="@color/card_surface"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="16dp"
                    app:strokeColor="@color/white_10"
                    app:strokeWidth="1dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/gradient_overlay"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Estimate"
                                android:textColor="@color/text_grey"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/cart_total_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱0"
                                android:textColor="@color/white"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_checkout"
                            android:layout_width="wrap_content"
                            android:layout_height="54dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:backgroundTint="@color/gold_accent"
                            android:text="Checkout"
                            android:textAllCaps="false"
                            android:textColor="@color/abyss"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp"
                            app:icon="@android:drawable/ic_media_play"
                            app:iconGravity="textEnd"
                            app:iconTint="@color/abyss" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

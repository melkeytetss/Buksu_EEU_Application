<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abyss">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="60dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage"
                android:textColor="@color/text_grey"
                android:textSize="13sp"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Products"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <!-- Search Bar -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/text_grey"
                app:hintTextColor="@color/gold_accent"
                android:textColorHint="@color/text_grey"
                app:boxStrokeColor="@color/gold_accent"
                android:hint="Search products...">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/search_product_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/admin_product_filters_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_prod_all"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="All"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/btn_blue"
                        android:textColor="@color/white" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_apparel"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="Apparel"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_accessories"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="Accessories"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_bags"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="Bags"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_headwear"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="Headwear"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_drinkware"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="Drinkware"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_home_decor"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="Home Decor"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_gift_sets"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="Gift Sets &amp; Boxes"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_crafts"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:text="Crafts &amp; Collectibles"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_filter_archived"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Archived"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:cornerRadius="999dp"
                        app:elevation="0dp"
                        android:backgroundTint="@color/soft_white"
                        android:textColor="@color/black" />
                </LinearLayout>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_products_admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:nestedScrollingEnabled="false" />

            <!-- Pagination Controls -->
            <LinearLayout
                android:id="@+id/pagination_layout_admin_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_prev_page_admin_prod"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:backgroundTint="@color/midnight"
                    android:text="← Prev"
                    android:textAllCaps="false"
                    android:textColor="@color/soft_white"
                    android:textSize="13sp"
                    app:cornerRadius="999dp"
                    app:elevation="0dp"
                    app:strokeColor="@color/electric_blue"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/tv_page_number_admin_prod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:text="Page 1 of 1"
                    android:textColor="@color/pale_mist"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_next_page_admin_prod"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:backgroundTint="@color/midnight"
                    android:text="Next →"
                    android:textAllCaps="false"
                    android:textColor="@color/soft_white"
                    android:textSize="13sp"
                    app:cornerRadius="999dp"
                    app:elevation="0dp"
                    app:strokeColor="@color/electric_blue"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/no_products_text_admin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:text="No products to show."
                android:textColor="@color/text_grey"
                android:visibility="gone"
                android:padding="32dp" />

            <!-- Bottom padding for FAB + nav -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="120dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB for Add Product -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_product"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:layout_marginBottom="96dp"
        android:backgroundTint="@color/gold_accent"
        android:text="Add Product"
        android:textColor="@color/abyss"
        android:textStyle="bold"
        app:iconTint="@color/abyss"
        app:icon="@android:drawable/ic_input_add"
        app:cornerRadius="16dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/bg_navy">

    <!-- FRAGMENT CONTAINER -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- FLOATING BOTTOM NAV CONTAINER -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/card_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/white_10">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_view"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@android:color/transparent"
            app:itemIconSize="26dp"
            app:itemIconTint="@color/bottom_nav_item_tint"
            app:itemTextColor="@color/bottom_nav_text_tint"
            app:labelVisibilityMode="unlabeled"
            app:itemActiveIndicatorStyle="@style/CustomIndicator"
            app:menu="@menu/bottom_nav_menu" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

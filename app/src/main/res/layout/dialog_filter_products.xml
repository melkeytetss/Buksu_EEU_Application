<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/deep_navy"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sort Products"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/rg_sort_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_sort_newest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Newest Arrivals"
            android:textColor="@color/white"
            android:buttonTint="@color/gold_accent"
            android:padding="12dp"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rb_sort_price_low"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Price: Low to High"
            android:textColor="@color/white"
            android:buttonTint="@color/gold_accent"
            android:padding="12dp"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rb_sort_price_high"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Price: High to Low"
            android:textColor="@color/white"
            android:buttonTint="@color/gold_accent"
            android:padding="12dp"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rb_sort_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name: A to Z"
            android:textColor="@color/white"
            android:buttonTint="@color/gold_accent"
            android:padding="12dp"
            android:textSize="16sp" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply_filter"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/electric_blue"
        android:text="Apply Sort"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="16dp" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/abyss">

    <!-- Ambient Glow Background -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="center"
        android:alpha="0.3"
        android:background="@drawable/glow_circle_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Animated Logo Container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/logo_container"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:alpha="0"
            android:scaleX="0.8"
            android:scaleY="0.8"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="80dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp"
                android:src="@drawable/logo" />
        </com.google.android.material.card.MaterialCardView>

        <!-- App Name / Branding -->
        <TextView
            android:id="@+id/app_name_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:alpha="0"
            android:letterSpacing="0.2"
            android:text="BUKSU EEU"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/app_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0"
            android:text="The University Store Experience"
            android:textColor="@color/text_grey"
            android:textSize="14sp" />

        <!-- Premium Loading Bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/splash_progress"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:alpha="0"
            android:indeterminate="true"
            app:indicatorColor="@color/gold_accent"
            app:trackColor="@color/white_10"
            app:trackCornerRadius="4dp"
            app:trackThickness="4dp" />

    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:alpha="0.5"
        android:text="Powered by Bukidnon State University"
        android:textColor="@color/text_grey"
        android:textSize="12sp" />

</FrameLayout>
